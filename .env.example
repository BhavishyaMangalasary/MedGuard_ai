# Copy this file to .env and fill in real values.
# Never commit your actual .env file -- it's already in .gitignore.

# Get a free key from Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Required by ADK when using the direct Gemini API (not Vertex AI)
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEDGUARD_ENCRYPTION_KEY=your_generated_fernet_key_here

# Optional -- controls logging behavior
# LOG_LEVEL: DEBUG | INFO | WARNING (default: WARNING)
# LOG_FORMAT: json | text (default: json, use text for local dev)
LOG_LEVEL=WARNING
LOG_FORMAT=text